# ==============================================================================
# ZC702 Constraints File for Ztachip (Option B — soc_base in PL)
# Verified against UG850 (ZC702 Board Guide) and UG865 (Zynq-7000 Pinout)
# ==============================================================================

# ------------------------------------------------------------------------------
# UART — Bank 33, LVCMOS25 (Kept from existing configuration)
# ------------------------------------------------------------------------------
# UART ports are routed through MIO (PS) on ZC702, not PL pins in this design.



# ------------------------------------------------------------------------------
# PL User LEDs — Bank 13 (VCCO = VADJ = 2.5V default, jumper J12 installed)
# UG850 Table 1-23: V7=DS18, W10=DS17, P18=DS16, P17=DS15
# Connected via TXS0108E level shifters, shared with PMOD2 header (J62)
# ------------------------------------------------------------------------------
set_property PACKAGE_PIN V7 [get_ports {led[0]}]
set_property PACKAGE_PIN W10 [get_ports {led[1]}]
set_property PACKAGE_PIN P18 [get_ports {led[2]}]
set_property PACKAGE_PIN P17 [get_ports {led[3]}]
set_property IOSTANDARD LVCMOS25 [get_ports {led[3]}]
set_property IOSTANDARD LVCMOS25 [get_ports {led[2]}]
set_property IOSTANDARD LVCMOS25 [get_ports {led[1]}]
set_property IOSTANDARD LVCMOS25 [get_ports {led[0]}]

# LED outputs are asynchronous — no timing requirement
set_false_path -to [get_ports {led[*]}]

# ------------------------------------------------------------------------------
# CRITICAL: Distributed RAM (LUTRAM) Timing Relaxation
#
# This constraint was present in the original Artix-7 main.xdc (lines 115-119)
# and is REQUIRED to prevent false hold-time violations through LUTRAM/DRAM/DROM
# primitives. Without this, Vivado reports thousands of false timing failures
# (1797 endpoints, WHS=-0.042ns, THS=-40.862ns in the failing build).
#
# The original constraint referenced port "clka" (from MIG). This generalized
# version applies to all paths through distributed RAM outputs, which is
# functionally equivalent and correct for the Zynq port.
# ------------------------------------------------------------------------------
set_false_path -through [get_pins -of_objects [get_cells -hier * -filter {PRIMITIVE_SUBGROUP==LUTRAM || PRIMITIVE_SUBGROUP==dram || PRIMITIVE_SUBGROUP==drom}] -filter DIRECTION==OUT]

# ------------------------------------------------------------------------------
# Inter-Clock Domain Crossing: clk_fpga_1 (200 MHz) <-> clk_fpga_0 (100 MHz)
#
# These two clocks are generated by independent PS7 FCLK PLL outputs. Vivado
# cannot prove they are related (TIMING-6/TIMING-7), so it applies zero Clock
# Pessimism Removal and worst-case skew analysis, causing 8 false setup
# violations (WNS=-0.075ns) on true-dual-port BRAM CDC paths.
#
# The ztachip RTL handles synchronization internally: BRAMs use port A at
# 200 MHz (write) and port B at 100 MHz (read), with read data registered
# into the clk_fpga_0 domain. These crossings are functionally safe.
# ------------------------------------------------------------------------------
set_false_path -from [get_clocks clk_fpga_1] -to [get_clocks clk_fpga_0]
set_false_path -from [get_clocks clk_fpga_0] -to [get_clocks clk_fpga_1]

# ------------------------------------------------------------------------------
# JTAG BSCAN Debug Clock (TCK) — VexRiscv Debug Interface
#
# The VexRiscv CPU uses a BSCAN primitive for JTAG debugging. Its TCK clock
# drives 43 registers/latches that Vivado cannot time (TIMING-17 critical
# warnings). This clock is completely asynchronous to the design clocks and
# only active when a JTAG debugger is connected.
#
# Define TCK as a clock and false-path all paths to/from it.
# ------------------------------------------------------------------------------
create_clock -period 100.000 -name jtag_tck [get_pins soc_base_inst/cpu_inst/bSCANE2_1/TCK]

set_false_path -from [get_clocks jtag_tck] -to [get_clocks clk_fpga_0]
set_false_path -from [get_clocks clk_fpga_0] -to [get_clocks jtag_tck]

# ==============================================================================
# Test 3 additions — PL push-buttons on Bank 13 (SW13 + SW14)
# UG850 Table 1-26: SW13=G19, SW14=F19 (LVCMOS25)
# ==============================================================================
set_property PACKAGE_PIN G19 [get_ports {pushbutton_pl[0]}]
set_property PACKAGE_PIN F19 [get_ports {pushbutton_pl[1]}]
set_property IOSTANDARD LVCMOS25 [get_ports {pushbutton_pl[1]}]
set_property IOSTANDARD LVCMOS25 [get_ports {pushbutton_pl[0]}]
set_false_path -from [get_ports {pushbutton_pl[*]}]

set_property MAX_FANOUT 16 [get_cells -hier -filter {PRIMITIVE_TYPE =~ FLOP_LATCH.*}]
